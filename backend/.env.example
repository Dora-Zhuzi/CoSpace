# ===== 全部可选：不配置也能用 SQLite + 本地实现端到端跑通 =====

# 存储（默认 SQLite + 本地文件夹）
# DATABASE_URL=sqlite+aiosqlite:///./docgen.db
# STORAGE_DIR=./storage

# 鉴权（生产请改）
# JWT_SECRET=change-me
# JWT_EXPIRE_DAYS=7

# CORS（前端地址）
# CORS_ORIGINS=["http://localhost:3000"]

# ===== 大模型（OpenAI 兼容接口）=====
# 留空 LLM_API_KEY 则自动降级到本地实现（摘要=抽取式，写作=拼接式）
# 接 DeepSeek：
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
#
# 接火山方舟 Ark：
# LLM_API_KEY=xxx
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=<your-endpoint-id>

# ===== 向量化 =====
# 装了 sentence-transformers 时加载该模型；否则用本地哈希向量
# EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# EMBEDDING_DIM=256
